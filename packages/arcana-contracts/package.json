{
  "name": "@kybernesis/arcana-contracts",
  "version": "1.1.0",
  "description": "Zod schemas, provider interfaces, and shared types for Arcana",
  "license": "MIT",
  "author": "David Cruwys (AppyDave)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./scopes": {
      "types": "./dist/scopes.d.ts",
      "default": "./dist/scopes.js"
    },
    "./memory": {
      "types": "./dist/memory.d.ts",
      "default": "./dist/memory.js"
    },
    "./entity": {
      "types": "./dist/entity.d.ts",
      "default": "./dist/entity.js"
    },
    "./edge": {
      "types": "./dist/edge.d.ts",
      "default": "./dist/edge.js"
    },
    "./fact": {
      "types": "./dist/fact.d.ts",
      "default": "./dist/fact.js"
    },
    "./insight": {
      "types": "./dist/insight.d.ts",
      "default": "./dist/insight.js"
    },
    "./agent-self": {
      "types": "./dist/agent-self.d.ts",
      "default": "./dist/agent-self.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "default": "./dist/logger.js"
    },
    "./query-result": {
      "types": "./dist/query-result.d.ts",
      "default": "./dist/query-result.js"
    },
    "./providers": {
      "types": "./dist/providers.d.ts",
      "default": "./dist/providers.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
