{
  "name": "@kybernesis/arcana-provider-libsql",
  "version": "0.4.0",
  "description": "LibSQL/SQLite StructuredStore provider for Arcana",
  "license": "MIT",
  "author": "David Cruwys (AppyDave)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
